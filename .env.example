# LLM API Key（必填，按使用的模型提供商填写）
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=

# MySQL 数据库连接（validate_sql 工具使用）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=

# LangSmith 可观测性（推荐开启）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_...
LANGSMITH_PROJECT=sql-assistant
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
